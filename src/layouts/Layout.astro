---
import "@/styles/index.css";
import ModalMenu from "@/components/modals/ModalMenu.astro";
import ModalReserva from "@/components/modals/ModalReserva.astro";
import ModalCondiciones from "@/components/modals/ModalCondiciones.astro";
import ModalCompartir from "@/components/modals/ModalCompartir.astro";
import ModalGaleria from "@/components/modals/ModalGaleria.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang?: string;
}

const { title, description, ogImage = "/og-image.jpg", lang = "es" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: "Casa del Aire",
  description: "Casa rural en la dehesa extremeña, a dos horas de Madrid. Piscina, chimenea y naturaleza. Capacidad para 6-8 personas.",
  url: "https://www.casadelaire.es",
  image: "https://www.casadelaire.es/images/01.webp",
  telephone: "+34637159169",
  email: "adan.housing@gmail.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "La Aldea del Obispo",
    addressRegion: "Cáceres",
    addressCountry: "ES",
  },
  sameAs: [
    "https://www.facebook.com/people/Casa-del-Aire/61566947403204/",
    "https://www.instagram.com/casadelaire_extremadura/",
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />

    <ModalMenu />
    <ModalReserva />
    <ModalCondiciones />
    <ModalCompartir />
    <ModalGaleria />

    <script>
      import { getLangFromStorage, LANGS } from "@/locales/index.ts";
      import type { Lang } from "@/locales/index.ts";

      async function applyLang(lang: Lang) {
        document.documentElement.lang = lang;
        localStorage.setItem("lang", lang);

        let translations: Record<string, unknown>;
        if (lang === "es") translations = (await import("@/locales/es.ts")).translations;
        else if (lang === "en") translations = (await import("@/locales/en.ts")).translations;
        else if (lang === "fr") translations = (await import("@/locales/fr.ts")).translations;
        else translations = (await import("@/locales/pt.ts")).translations;

        function getVal(obj: Record<string, unknown>, path: string): string {
          return path
            .split(".")
            .reduce(
              (acc: unknown, k) =>
                acc && typeof acc === "object" ? (acc as Record<string, unknown>)[k] : undefined,
              obj
            ) as string;
        }

        (window as any).__lang = translations;

        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n");
          if (!key) return;
          const val = getVal(translations, key);
          if (typeof val === "string") el.textContent = val;
        });

        document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
          btn.classList.toggle("is-active", btn.getAttribute("data-lang-btn") === lang);
        });
      }

      applyLang(getLangFromStorage());

      document.addEventListener("click", (e) => {
        const btn = (e.target as Element).closest("[data-lang-btn]");
        if (!btn) return;
        const lang = btn.getAttribute("data-lang-btn") as Lang;
        if (lang && LANGS.includes(lang)) applyLang(lang);
      });

      function setNavbarModalState() {
        const anyOpen = document.querySelector(".modal.is-open") !== null;
        document.querySelector(".navbar")?.classList.toggle("modal-active", anyOpen);
      }

      document.addEventListener("click", (e) => {
        const trigger = (e.target as Element).closest("[data-modal-open]");
        if (trigger) {
          const id = trigger.getAttribute("data-modal-open");
          document.getElementById(id!)?.classList.add("is-open");
          setNavbarModalState();
          return;
        }
        const close = (e.target as Element).closest("[data-modal-close]");
        if (close) {
          close.closest(".modal")?.classList.remove("is-open");
          setNavbarModalState();
          return;
        }
        const overlay = (e.target as Element).closest(".modal__overlay");
        if (overlay) {
          overlay.closest(".modal")?.classList.remove("is-open");
          setNavbarModalState();
        }
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          document.querySelectorAll(".modal.is-open").forEach((m) => m.classList.remove("is-open"));
          setNavbarModalState();
        }
      });
    </script>
  </body>
</html>
