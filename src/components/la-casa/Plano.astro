---
---

<section class="content-wrapper">
  <h2 class="large" data-i18n="pages.la-casa.plan.title">Plano de la casa</h2>
  <p class="regular" style="color: var(--bl-100);" data-i18n="pages.la-casa.plan.description">
    Distribución de la planta baja y primera planta
  </p>

  <div class="plano-thumb" onclick="window.__openPlano?.()">
    <img
      src="/images/house-plan01.webp"
      alt="Plano de la casa"
      loading="lazy"
    />
  </div>
</section>

<style>
  .plano-thumb {
    cursor: pointer;
    border-radius: var(--border-radius-md);
    border: var(--border-thin) var(--wh-300);
    overflow: hidden;
    height: 280px;
  }

  .plano-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }

  .plano-thumb:hover img {
    transform: scale(1.05);
  }
</style>

<script>
  (window as any).__openPlano = () => {
    const allImages = [
      ...Array.from({ length: 38 }, (_, i) => `/images/${String(i + 1).padStart(2, "0")}.webp`),
      "/images/house-plan01.webp",
    ];
    (window as any).openGaleria?.(allImages, 38);
  };
</script>
