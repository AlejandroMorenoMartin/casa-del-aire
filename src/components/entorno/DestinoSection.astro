---
interface Props {
  titleKey: string;
  title: string;          // nombre del destino, para el alt de las imágenes
  pKey: string;
  images: string[];       // 2 imágenes de este destino
  allImages: string[];    // las 18 de entorno — para la galería completa
  startIndex: number;     // índice de la primera imagen de este destino en allImages
}
const { titleKey, title, pKey, images, allImages, startIndex } = Astro.props;
const allJson = JSON.stringify(allImages);
---

<section class="content-wrapper" style="border-top: var(--border-thin) var(--wh-300);">
  <div style="display: flex; flex-direction: column; gap: var(--sp-xxs); margin-bottom: var(--sp-lg);">
    <h2 class="large-bold" data-i18n={titleKey}></h2>
  </div>

  <!-- 2 imágenes -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-md); margin-bottom: var(--sp-xl);">
    {
      images.map((src, i) => (
        <div
          style="overflow: hidden; height: 18rem; cursor: pointer; border-radius: var(--border-radius-sm);"
          onclick={`window.openGaleria(${allJson}, ${startIndex + i}, 'environment')`}
        >
          <img
            src={src}
            alt={`${title} — entorno de La Casa del Aire`}
            loading="lazy"
            style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s ease;"
            onmouseover="this.style.transform='scale(1.04)'"
            onmouseout="this.style.transform='scale(1)'"
          />
        </div>
      ))
    }
  </div>

  <p class="regular" style="color: var(--bl-300);" data-i18n={pKey}></p>
</section>
